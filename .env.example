# Search data paths
INDEX_SOURCE_PATH=data/products.csv
INDEX_SNAPSHOT_PATH=data/index_snapshot.pkl

# API route prefix
API_PREFIX=/api/v1

# CORS settings (comma-separated values)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_METHODS=GET
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=false
